# =============================================================================
# Nifty AI Trader - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# NEVER commit .env to git!
# =============================================================================

# -----------------------------------------------------------------------------
# Fyers API Credentials
# Get these from: https://myapi.fyers.in/dashboard
# -----------------------------------------------------------------------------
FYERS_APP_ID=your_app_id_here
FYERS_SECRET_KEY=your_secret_key_here
FYERS_REDIRECT_URI=http://localhost:8000/api/v1/auth/callback

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=nifty_trader
DB_USER=trader
DB_PASSWORD=change_me_in_production
DATABASE_URL=postgresql+asyncpg://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

# -----------------------------------------------------------------------------
# Redis Configuration
# -----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}/${REDIS_DB}

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=DEBUG
SECRET_KEY=change_me_to_random_string_in_production

# -----------------------------------------------------------------------------
# Trading Configuration
# -----------------------------------------------------------------------------
TRADING_MODE=paper
MAX_DAILY_LOSS_PCT=2.0
MAX_POSITION_SIZE_PCT=5.0
MAX_OPEN_POSITIONS=3

# -----------------------------------------------------------------------------
# Data Collection
# -----------------------------------------------------------------------------
FYERS_RATE_LIMIT_PER_SEC=1
TICK_BATCH_INSERT_INTERVAL=10
HISTORICAL_DATA_RETENTION_DAYS=730

# -----------------------------------------------------------------------------
# Monitoring
# -----------------------------------------------------------------------------
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
