# =============================================================================
# Nifty AI Trader - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# NEVER commit .env to git!
# =============================================================================

# -----------------------------------------------------------------------------
# Fyers API Credentials
# Get these from: https://myapi.fyers.in/dashboard
# -----------------------------------------------------------------------------
FYERS_APP_ID=your_app_id_here
FYERS_SECRET_KEY=your_secret_key_here
FYERS_REDIRECT_URI=https://trade.fyers.in/api-login/redirect-uri/index.html
FINNHUB_API_KEY=
ALPHAVANTAGE_API_KEY=

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=nifty_trader
DB_USER=trader
DB_PASSWORD=change_me_in_production
DATABASE_URL=postgresql+asyncpg://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

# -----------------------------------------------------------------------------
# Redis Configuration
# -----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}/${REDIS_DB}

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_NAME_BASE=AI TRADER
NEXT_PUBLIC_APP_INSTANCE_LABEL=LOCAL
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=DEBUG
SECRET_KEY=change_me_to_random_string_in_production

# -----------------------------------------------------------------------------
# Trading Configuration
# -----------------------------------------------------------------------------
TRADING_MODE=paper
MAX_DAILY_LOSS_PCT=2.0
MAX_POSITION_SIZE_PCT=5.0
MAX_CONCENTRATION_PCT=30.0
MAX_OPEN_POSITIONS=3
MAX_TRADE_RISK_PCT=0.5

# -----------------------------------------------------------------------------
# AI Agent Defaults
# -----------------------------------------------------------------------------
AGENT_AUTO_START=false
AGENT_SCAN_INTERVAL=30
AGENT_DEFAULT_TIMEFRAME=5
AGENT_EXECUTION_TIMEFRAMES=3,5,15
AGENT_REFERENCE_TIMEFRAMES=60,D
#AGENT_DEFAULT_SYMBOLS=NSE:NIFTY50-INDEX,NSE:NIFTYBANK-INDEX,NSE:FINNIFTY-INDEX,NSE:NIFTYMIDCAP50-INDEX,BSE:SENSEX-INDEX,NSE:RELIANCE-EQ,NSE:TCS-EQ,NSE:INFY-EQ,NSE:HDFCBANK-EQ,NSE:ICICIBANK-EQ,NSE:HINDUNILVR-EQ,NSE:SBIN-EQ,NSE:BHARTIARTL-EQ,NSE:ITC-EQ,NSE:KOTAKBANK-EQ,NSE:LT-EQ,NSE:AXISBANK-EQ,NSE:ASIANPAINT-EQ,NSE:MARUTI-EQ,NSE:BAJFINANCE-EQ,NSE:HCLTECH-EQ,NSE:WIPRO-EQ,NSE:TITAN-EQ,NSE:SUNPHARMA-EQ,NSE:ULTRACEMCO-EQ,NSE:ONGC-EQ,NSE:NTPC-EQ,NSE:POWERGRID-EQ,NSE:NESTLEIND-EQ,NSE:TECHM-EQ,NSE:CIPLA-EQ,NSE:DIVISLAB-EQ,NSE:GRASIM-EQ,NSE:ADANIPORTS-EQ,NSE:BAJAJ-AUTO-EQ,NSE:HEROMOTOCO-EQ,NSE:EICHERMOT-EQ,NSE:APOLLOHOSP-EQ,NSE:TATAMOTORS-EQ,NSE:TATASTEEL-EQ,NSE:JSWSTEEL-EQ,NSE:INDUSINDBK-EQ,NSE:HINDALCO-EQ,NSE:COALINDIA-EQ,NSE:DRREDDY-EQ,NSE:BPCL-EQ,NSE:TATACONSUM-EQ,NSE:BRITANNIA-EQ,NSE:BAJAJFINSV-EQ,NSE:SHREECEM-EQ,NSE:SBILIFE-EQ,NSE:HDFCLIFE-EQ,NSE:ADANIENT-EQ,NSE:LTIM-EQ,NSE:MM-EQ
AGENT_US_SYMBOLS=US:SPY,US:QQQ,US:DIA,US:IWM,US:AAPL,US:AMZN,US:JPM,US:XOM,US:UNH,US:CAT
AGENT_CRYPTO_SYMBOLS=CRYPTO:BTCUSDT,CRYPTO:ETHUSDT,CRYPTO:BNBUSDT,CRYPTO:SOLUSDT,CRYPTO:XRPUSDT,CRYPTO:ADAUSDT,CRYPTO:DOGEUSDT,CRYPTO:AVAXUSDT,CRYPTO:DOTUSDT,CRYPTO:LINKUSDT
AGENT_TRADE_NSE_WHEN_OPEN=true
AGENT_TRADE_US_WHEN_OPEN=true
AGENT_TRADE_US_OPTIONS=true
AGENT_TRADE_CRYPTO_24X7=true
AGENT_LIBERAL_BOOTSTRAP_ENABLED=true
AGENT_BOOTSTRAP_CYCLES=300
AGENT_BOOTSTRAP_SIZE_MULTIPLIER=2.0
AGENT_BOOTSTRAP_MAX_CONCENTRATION_PCT=100.0
AGENT_BOOTSTRAP_MAX_OPEN_POSITIONS=20
AGENT_BOOTSTRAP_RISK_PER_TRADE_PCT=2.0
AGENT_OPTION_TIME_EXIT_MINUTES=30
AGENT_OPTION_DEFAULT_STOP_LOSS_PCT=10.0
AGENT_OPTION_DEFAULT_TARGET_PCT=18.0
AGENT_REINFORCEMENT_ENABLED=true
AGENT_REINFORCEMENT_ALPHA=0.2
AGENT_REINFORCEMENT_SIZE_BOOST_PCT=60.0

# -----------------------------------------------------------------------------
# Data Collection
# -----------------------------------------------------------------------------
FYERS_RATE_LIMIT_PER_SEC=1
TICK_BATCH_INSERT_INTERVAL=10
HISTORICAL_DATA_RETENTION_DAYS=730

# -----------------------------------------------------------------------------
# Monitoring
# -----------------------------------------------------------------------------
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000

# -----------------------------------------------------------------------------
# Telegram Notifications
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_STATUS_INTERVAL_MINUTES=30

# -----------------------------------------------------------------------------
# FX Reference (for INR consolidated cross-market P/L)
# -----------------------------------------------------------------------------
USD_INR_REFERENCE_RATE=83.0
