# AWS account/region
AWS_REGION=ap-south-1
AWS_ACCOUNT_ID=123456789012

# ECR images
BACKEND_IMAGE=123456789012.dkr.ecr.ap-south-1.amazonaws.com/nifty-ai-backend:latest
FRONTEND_IMAGE=123456789012.dkr.ecr.ap-south-1.amazonaws.com/nifty-ai-frontend:latest

# Public endpoint
PUBLIC_HOST=your-ec2-public-ip
FRONTEND_PORT=80
NEXT_PUBLIC_APP_NAME_BASE=AI TRADER
NEXT_PUBLIC_APP_INSTANCE_LABEL=AWS

# Core secrets/runtime
SECRET_KEY=change_me
DB_NAME=nifty_trader
DB_USER=trader
DB_PASSWORD=change_me
REDIS_DB=0
REDIS_PASSWORD=

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_STATUS_INTERVAL_MINUTES=30
USD_INR_REFERENCE_RATE=83.0
TRADING_MODE=paper
AGENT_AUTO_START=true
AGENT_SCAN_INTERVAL=30
AGENT_DEFAULT_TIMEFRAME=5
AGENT_EXECUTION_TIMEFRAMES=3,5,15
AGENT_REFERENCE_TIMEFRAMES=60,D
AGENT_DEFAULT_SYMBOLS=NSE:NIFTY50-INDEX,NSE:NIFTYBANK-INDEX,NSE:FINNIFTY-INDEX,NSE:NIFTYMIDCAP50-INDEX,BSE:SENSEX-INDEX,NSE:RELIANCE-EQ,NSE:TCS-EQ,NSE:INFY-EQ,NSE:HDFCBANK-EQ,NSE:ICICIBANK-EQ,NSE:HINDUNILVR-EQ,NSE:SBIN-EQ,NSE:BHARTIARTL-EQ,NSE:ITC-EQ,NSE:KOTAKBANK-EQ,NSE:LT-EQ,NSE:AXISBANK-EQ,NSE:ASIANPAINT-EQ,NSE:MARUTI-EQ,NSE:BAJFINANCE-EQ,NSE:HCLTECH-EQ,NSE:WIPRO-EQ,NSE:TITAN-EQ,NSE:SUNPHARMA-EQ,NSE:ULTRACEMCO-EQ,NSE:ONGC-EQ,NSE:NTPC-EQ,NSE:POWERGRID-EQ,NSE:NESTLEIND-EQ,NSE:TECHM-EQ,NSE:CIPLA-EQ,NSE:DIVISLAB-EQ,NSE:GRASIM-EQ,NSE:ADANIPORTS-EQ,NSE:BAJAJ-AUTO-EQ,NSE:HEROMOTOCO-EQ,NSE:EICHERMOT-EQ,NSE:APOLLOHOSP-EQ,NSE:TATAMOTORS-EQ,NSE:TATASTEEL-EQ,NSE:JSWSTEEL-EQ,NSE:INDUSINDBK-EQ,NSE:HINDALCO-EQ,NSE:COALINDIA-EQ,NSE:DRREDDY-EQ,NSE:BPCL-EQ,NSE:TATACONSUM-EQ,NSE:BRITANNIA-EQ,NSE:BAJAJFINSV-EQ,NSE:SHREECEM-EQ,NSE:SBILIFE-EQ,NSE:HDFCLIFE-EQ,NSE:ADANIENT-EQ,NSE:LTIM-EQ,NSE:MM-EQ
AGENT_US_SYMBOLS=US:SPY,US:QQQ,US:DIA,US:IWM,US:AAPL,US:AMZN,US:JPM,US:XOM,US:UNH,US:CAT
AGENT_CRYPTO_SYMBOLS=CRYPTO:BTCUSDT,CRYPTO:ETHUSDT,CRYPTO:BNBUSDT,CRYPTO:SOLUSDT,CRYPTO:XRPUSDT,CRYPTO:ADAUSDT,CRYPTO:DOGEUSDT,CRYPTO:AVAXUSDT,CRYPTO:DOTUSDT,CRYPTO:LINKUSDT
