# AWS account/region
AWS_REGION=ap-south-1
AWS_ACCOUNT_ID=123456789012

# ECR images
BACKEND_IMAGE=123456789012.dkr.ecr.ap-south-1.amazonaws.com/nifty-ai-backend:latest
FRONTEND_IMAGE=123456789012.dkr.ecr.ap-south-1.amazonaws.com/nifty-ai-frontend:latest
EXECUTION_CORE_IMAGE=123456789012.dkr.ecr.ap-south-1.amazonaws.com/nifty-ai-execution-core:latest

# Deployment mode
DEPLOY_SUBSECOND_STACK=false
SUBSECOND_MIN_MEMORY_GB=8
ALLOW_UNDERSIZED_SUBSECOND_STACK=false
ENSURE_SWING_RESEARCH_ARTIFACTS=true
SWING_RESEARCH_SKIP_EXISTING=true

# Public endpoint
PUBLIC_HOST=your-ec2-public-ip
FRONTEND_PORT=80
BACKEND_PUBLIC_PORT=8000
PUBLIC_WS_URL=ws://your-ec2-public-ip:8000/api/v1
NEXT_PUBLIC_APP_NAME_BASE=AI TRADER
NEXT_PUBLIC_APP_INSTANCE_LABEL=AWS
APP_STARTUP_TASK_STAGGER_MS=750

# Core secrets/runtime
SECRET_KEY=change_me
DB_NAME=nifty_trader
DB_USER=trader
DB_PASSWORD=change_me
REDIS_DB=0
REDIS_PASSWORD=

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_STATUS_INTERVAL_MINUTES=30
USD_INR_REFERENCE_RATE=83.0
TRADING_MODE=paper
RISK_CIRCUIT_BREAKER_ENABLED=false
AGENT_AUTO_START=true
AGENT_AUTO_START_DELAY_SECONDS=20
AGENT_SCAN_INTERVAL=30
AGENT_PERIODIC_SCAN_BATCH_SIZE=96
AGENT_STARTUP_INITIAL_SCAN_LIMIT=24
AGENT_STARTUP_SCAN_LIMIT_STEP=24
AGENT_STARTUP_RAMP_CYCLES=4
AGENT_DEFAULT_TIMEFRAME=5
AGENT_EXECUTION_TIMEFRAMES=3,5,15
AGENT_REFERENCE_TIMEFRAMES=60,D
# Leave AGENT_DEFAULT_SYMBOLS unset to use the built-in full FnO equity universe.
# AGENT_DEFAULT_SYMBOLS=
# Leave AGENT_US_SYMBOLS unset to use the built-in 200-stock US swing universe.
# AGENT_US_SYMBOLS=
# Leave AGENT_CRYPTO_SYMBOLS unset to use the built-in crypto universe.
# AGENT_CRYPTO_SYMBOLS=
AGENT_TRADE_NSE_WHEN_OPEN=true
AGENT_TRADE_US_WHEN_OPEN=true
AGENT_TRADE_US_OPTIONS=true
AGENT_TRADE_CRYPTO_24X7=true
AGENT_LIBERAL_BOOTSTRAP_ENABLED=true
AGENT_BOOTSTRAP_CYCLES=600
AGENT_BOOTSTRAP_SIZE_MULTIPLIER=2.0
AGENT_BOOTSTRAP_MAX_CONCENTRATION_PCT=100.0
AGENT_BOOTSTRAP_MAX_OPEN_POSITIONS=20
AGENT_BOOTSTRAP_RISK_PER_TRADE_PCT=2.0
AGENT_INDIA_CAPITAL=250000
AGENT_US_CAPITAL=250000
AGENT_CRYPTO_CAPITAL=250000
AGENT_INDIA_MAX_INSTRUMENT_PCT=25
AGENT_US_MAX_INSTRUMENT_PCT=20
AGENT_CRYPTO_MAX_INSTRUMENT_PCT=20
AGENT_REINFORCEMENT_ENABLED=true
AGENT_REINFORCEMENT_ALPHA=0.2
AGENT_REINFORCEMENT_SIZE_BOOST_PCT=60.0
AGENT_STRATEGY_CAPITAL_BUCKET_ENABLED=false
AGENT_STRATEGY_MAX_CONCURRENT_POSITIONS=4

# Optional data/broker providers
FINNHUB_API_KEY=
ALPHAVANTAGE_API_KEY=
US_PROVIDER_RATE_LIMIT_COOLDOWN_SECONDS=900
US_PROVIDER_AUTH_COOLDOWN_SECONDS=3600
US_PROVIDER_ERROR_COOLDOWN_SECONDS=180
US_PROVIDER_ERROR_THRESHOLD=3
FYERS_APP_ID=
FYERS_SECRET_KEY=
FYERS_REDIRECT_URI=https://trade.fyers.in/api-login/redirect-uri/index.html
FYERS_REDIRECT_FRONTEND_URL=http://your-ec2-public-ip/settings

# Optional sub-second stack settings
EXECUTION_CORE_BACKEND=rust
EXECUTION_TRANSPORT=nats
NATS_ENABLED=true
NATS_URL=nats://nats:4222
NATS_STREAM_PREFIX=ai_trader
KAFKA_ENABLED=true
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC_PREFIX=ai_trader
KAFKA_KRAFT_CLUSTER_ID=abcdefghijklmnopqrstuv
CLICKHOUSE_ENABLED=true
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_NATIVE_PORT=9000
CLICKHOUSE_DATABASE=ai_trader
CLICKHOUSE_USER=ai_trader_app
CLICKHOUSE_PASSWORD=change_me
QUESTDB_ENABLED=true
QUESTDB_HOST=questdb
QUESTDB_HTTP_PORT=9000
QUESTDB_PG_PORT=8812
QUESTDB_ILP_PORT=9009
TRANSPORT_MIRROR_ENABLED=true
TRANSPORT_MIRROR_EMBEDDED_ENABLED=false
ANALYTICS_CONSUMER_ENABLED=true
ANALYTICS_CONSUMER_EMBEDDED_ENABLED=false
ANALYTICS_CONSUMER_SOURCE=kafka
ANALYTICS_CONSUMER_GROUP_ID=ai_trader_analytics
EVENT_DIRECT_ANALYTICS_WRITE_ENABLED=false
AGENT_LATENCY_METRICS_ENABLED=true
AGENT_LATENCY_METRICS_WINDOW=512
AGENT_EVENT_DRIVEN_ENABLED=true
AGENT_EVENT_DRIVEN_MARKETS=NSE,CRYPTO
AGENT_EVENT_DRIVEN_DEBOUNCE_MS=750
AGENT_EVENT_DRIVEN_BATCH_SIZE=6
EXECUTION_CORE_RUST_LOG=info
EXECUTION_CORE_MAX_TRACKED_SYMBOLS=256
EXECUTION_CORE_SIGNAL_TIMEFRAMES=1,3,5
EXECUTION_CORE_EMA_FAST_PERIOD=5
EXECUTION_CORE_EMA_SLOW_PERIOD=9
EXECUTION_CORE_SIGNAL_COOLDOWN_SECONDS=30
